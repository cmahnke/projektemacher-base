{{- $pages := where .Site.RegularPages "Params.displayinlist" "!=" false -}}

{{- $section := "post" -}}
{{- $blogType := "Blog" -}}
{{- $topType := "WebSite" -}}
{{- if isset "section" .Params -}}
  {{- $section = .Params.section -}}
{{- end -}}
{{- if isset "type" .Params -}}
  {{- $blogType = .Params.type -}}
{{- end -}}

{{- $pages = where $pages "Section" $section -}}

{{- $pageList := slice -}}
{{- range $page := $pages -}}
  {{- $schemaOrg := transform.Unmarshal (partial "metadata/schema.org/util/post.html" .) -}}
  {{- $schemaOrg = $schemaOrg | merge (dict "@type" "BlogPosting") -}}
  {{- $author := transform.Unmarshal (partialCached "metadata/schema.org/util/author.html" .) -}}

  {{- $about := partial "metadata/schema.org/util/about.html" $page | transform.Unmarshal (dict "format" "json") -}}
  {{- with $about -}}
    {{- $schemaOrg = $schemaOrg | merge (dict "about" .) -}}
  {{- end -}}
  {{- with $author -}}
    {{- $schemaOrg = $schemaOrg | merge (dict "author" .) -}}
  {{- end -}}
  {{- with $schemaOrg  -}}
    {{- $pageList = $pageList | append $schemaOrg -}}
  {{- end -}}
{{- end -}}

{{- $name := site.Title -}}
{{- $siteURL := site.BaseURL -}}

{{- if ne $section "" -}}
  {{- with site.GetPage $section -}}
    {{- $siteURL = (.OutputFormats.Get "html").Permalink -}}
    {{- $name = printf "%s - %s" $name .Title -}}
  {{- end -}}
{{- end -}}

{{- $author := transform.Unmarshal (partialCached "metadata/schema.org/util/author.html" .) -}}
{{- $blog := dict "@context" "https://schema.org/" "@type" $blogType
  "author" $author
  "blogPost" $pageList "@id" $siteURL "mainEntityOfPage" $siteURL "name" $name -}}

{{- $hasPart := slice $blog -}}



{{- $website := dict "@context" "https://schema.org/" "@type" $topType "hasPart" $hasPart "author" $author "name" site.Title "url" site.BaseURL -}}

{{- $website | jsonify -}}
